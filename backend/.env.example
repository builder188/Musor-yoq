# ============================================================
#  Musir Yo'q — Backend muhit o'zgaruvchilari (.env)
#  Bu faylni .env ga nusxa qiling va qiymatlarni to'ldiring:
#    Windows:  copy .env.example .env
#    Linux/Mac: cp .env.example .env
# ============================================================

# --- Telegram bot ---
# @BotFather dan oling: Telegram'da @BotFather ga yozing -> /newbot -> token oladi.
BOT_TOKEN=123456789:AAExampleTokenReplaceMeWithRealOne

# Ruxsat berilgan Telegram raqamli IDlar. @userinfobot ga yozing -> ID ni ko'rsatadi.
# HAR BIR ID — butunlay alohida, mustaqil ma'lumotlar to'plamiga ega (multi-tenant):
# bittasi kiritgan mijoz/xizmat/moliya boshqasida ko'rinmaydi.
# Bitta ID: 123456789
# Bir nechta ID: 6028715926,606578823
ALLOWED_TELEGRAM_IDS=123456789

# (Eski nom — hali ham qabul qilinadi, ALLOWED_TELEGRAM_IDS bo'lmasa ishlatiladi.)
# OWNER_TELEGRAM_ID=123456789

# Migratsiya: eski (bitta-egali) ma'lumotlar shu egaga biriktiriladi. Bo'sh bo'lsa
# ro'yxatdagi birinchi ID ishlatiladi. Odatda o'zgartirish shart emas.
# LEGACY_OWNER_ID=123456789

# --- MongoDB ---
# Railway MongoDB yoki MongoDB Atlas connection string.
# Kod MONGODB_URI bo'lmasa MONGO_URL, MONGO_PRIVATE_URL, MONGO_PUBLIC_URL yoki
# mongodb:// bilan boshlanadigan DATABASE_URL qiymatini ham avtomatik qabul qiladi.
# Railway Mongo bo'lak env bersa: MONGOUSER, MONGOPASSWORD, MONGOHOST, MONGOPORT,
# MONGODATABASE qiymatlaridan URL avtomatik yig'iladi.
# Misol (Atlas): mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/musiryoq
# Misol (lokal): mongodb://127.0.0.1:27017/musiryoq
MONGODB_URI=mongodb://127.0.0.1:27017/musiryoq

# --- Google Gemini AI ---
# https://aistudio.google.com/app/apikey dan bepul API key oling.
GEMINI_API_KEY=AIzaSyExampleReplaceMeWithRealKey

# Gemini model nomi (ixtiyoriy). Standart: gemini-2.5-flash (aqilliroq, tabiiy javob).
# Tezroq/arzonroq variant: gemini-2.5-flash-lite. Eslatma: gemini-2.0 / 1.5 modellari
# Google tomonidan to'xtatilgan.
GEMINI_MODEL=gemini-2.5-flash

# --- Server ---
# Ishlash rejimi: development yoki production
NODE_ENV=development

# Express server porti
PORT=3000

# Vaqt mintaqasi (eslatmalar va sanalar uchun)
TZ=Asia/Tashkent

# --- Bot rejimi ---
# polling  = lokal/dev uchun (oson, domen shart emas)
# webhook  = Railway/production uchun (RAILWAY_STATIC_URL kerak)
# Railway'da public domain bor bo'lsa, BOT_MODE=polling xato conflict bermasligi uchun
# runtime avtomatik webhook rejimiga o'tadi.
BOT_MODE=polling

# Railway avtomatik beradigan public URL (webhook rejimida kerak).
# RAILWAY_STATIC_URL bo'lmasa RAILWAY_PUBLIC_DOMAIN, RAILWAY_PUBLIC_URL,
# PUBLIC_URL yoki APP_URL ham qabul qilinadi.
# Misol: musiryoq-production.up.railway.app  (https:// yozish shart emas)
RAILWAY_STATIC_URL=

# Mini App ochiladigan to'liq URL (bot tugmasi shu yerga ochadi).
# Lokal sinov uchun ngrok yoki Railway URL ishlatiladi. Misol: https://xxxx.up.railway.app
MINIAPP_URL=

# --- Xavfsizlik ---
# O'chirishni tasdiqlash kodi. Standart: 1990
CONFIRM_DELETE_CODE=1990

# initData tekshiruvini dev rejimida o'tkazib yuborish (1 = o'chirib qo'yish).
# Productionda HAR DOIM 0 bo'lsin.
AUTH_DEV_BYPASS=0
